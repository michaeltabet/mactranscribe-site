---
import Base from '../layouts/Base.astro';

// Already signed in? Bounce to the dashboard.
if (Astro.locals.session) {
  return Astro.redirect('/dashboard');
}

const returnTo = Astro.url.searchParams.get('returnTo') ?? '/dashboard';
const error = Astro.url.searchParams.get('error');
const enc = encodeURIComponent(returnTo);
---

<Base title="Sign in — MacTranscribe" bareNav>
  <section class="auth">
    <div class="wrap">
      <div class="card" data-reveal>
        <p class="kicker">Welcome back</p>
        <h2>Sign in to MacTranscribe</h2>
        <p class="lead">
          Use your MacTranscribe account to manage your plan and grab your Pro license. Authentication
          is handled by Keycloak.
        </p>

        {error && <p class="err" role="alert">Sign-in failed: {error}. Please try again.</p>}

        <a class="btn btn-primary full google" href={`/api/auth/login?idp=google&returnTo=${enc}`}>
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="#fff"
              d="M21.35 11.1H12v3.83h5.35c-.23 1.4-1.66 4.1-5.35 4.1a5.83 5.83 0 0 1 0-11.66c1.66 0 2.78.7 3.42 1.31l2.6-2.5C16.4 3.65 14.4 2.8 12 2.8a9.2 9.2 0 1 0 0 18.4c5.31 0 8.83-3.73 8.83-8.99 0-.6-.07-1.06-.18-1.51Z"
            ></path>
          </svg>
          Continue with Google
        </a>

        <div class="or"><span>or</span></div>

        <a class="btn btn-ghost full" href={`/api/auth/login?returnTo=${enc}`}>
          Sign in with email
        </a>

        <p class="note">
          New here? Choose <b>Email</b> — you can create an account on the Keycloak screen. By
          continuing you agree to our terms.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .auth {
    min-height: 70vh;
    display: grid;
    place-items: center;
    padding-top: calc(var(--space-section) * 0.5);
  }
  .auth .wrap {
    width: 100%;
    max-width: 460px;
  }
  .card {
    position: relative;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, #0f141c, #0b0e13);
    padding: clamp(1.8rem, 1.2rem + 2vw, 2.8rem);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(90% 60% at 50% -10%, rgba(91, 140, 255, 0.16), transparent 60%);
    pointer-events: none;
  }
  .card > * {
    position: relative;
  }
  h2 {
    font-size: 1.7rem;
  }
  .lead {
    font-size: 14.5px;
    margin-bottom: 26px;
  }
  .full {
    width: 100%;
  }
  .google {
    gap: 10px;
  }
  .or {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 18px 0;
    color: var(--faint);
    font-size: 12px;
  }
  .or::before,
  .or::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .err {
    background: rgba(255, 95, 87, 0.1);
    border: 1px solid rgba(255, 95, 87, 0.3);
    color: #ffb3ae;
    padding: 10px 12px;
    border-radius: var(--radius);
    font-size: 13px;
    margin-bottom: 18px;
  }
  .note {
    font-size: 12.5px;
    color: var(--faint);
    margin: 18px 0 0;
  }
</style>
