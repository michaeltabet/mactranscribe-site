---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Practice from '../components/Practice.astro';
import PricingCards from '../components/PricingCards.astro';
import GetStartedCTA from '../components/GetStartedCTA.astro';
---

<Base>
  <Hero />
  <Features />
  <Practice />

  <section id="pricing">
    <div class="wrap">
      <p class="kicker" data-reveal>Pricing</p>
      <h2 data-reveal>Start free. Go Pro when your team onboards together.</h2>
      <p class="lead" data-reveal>
        Free for a single new hire on your own AI keys. Pro adds the shared onboarding layer — a team
        knowledge base, role-based ramp-up playbooks, and reusable answer packs.
      </p>
      <PricingCards />
    </div>
  </section>

  <GetStartedCTA />
</Base>
