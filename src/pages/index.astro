---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Practice from '../components/Practice.astro';
import PricingCards from '../components/PricingCards.astro';
import DownloadCTA from '../components/DownloadCTA.astro';
---

<Base>
  <Hero />
  <Features />
  <Practice />

  <section id="pricing">
    <div class="wrap">
      <p class="kicker" data-reveal>Pricing</p>
      <h2 data-reveal>Start free. Go Pro when you mean it.</h2>
      <p class="lead" data-reveal>
        The app runs free on your own AI keys. Pro adds the hosted extras — sync, the per-role practice
        console, and priority builds.
      </p>
      <PricingCards />
    </div>
  </section>

  <DownloadCTA />
</Base>
