---
import Base from '../layouts/Base.astro';
import { DOWNLOAD_URL } from '../lib/constants';
---

<Base title="Download — MacTranscribe" description="Download the notarized MacTranscribe macOS app. Apple Silicon, macOS 14+. Bring your own AI keys.">
  <section class="dl">
    <div class="wrap">
      <p class="kicker" data-reveal>Download</p>
      <h2 data-reveal>Get MacTranscribe for macOS</h2>
      <p class="lead" data-reveal>
        The button below always grabs the <b>latest notarized release</b> straight from GitHub — no
        stale mirrors, no installers, just the signed app.
      </p>

      <div data-reveal>
        <a class="btn btn-primary btn-lg" href={DOWNLOAD_URL} rel="noopener">↓ Download latest release</a>
        <p class="track">
          Tracks <code>github.com/michaeltabet/mac-transcribe/releases/latest</code>.
        </p>
      </div>

      <div class="steps" data-reveal-group>
        <div class="step" data-reveal>
          <span class="n">1</span>
          <div>
            <h3>Install</h3>
            <p>Open the download and drag <b>MacTranscribe</b> into your Applications folder.</p>
          </div>
        </div>
        <div class="step" data-reveal>
          <span class="n">2</span>
          <div>
            <h3>Grant permissions</h3>
            <p>
              In System Settings → Privacy &amp; Security, enable <b>Screen Recording</b> and
              <b>Microphone</b> for MacTranscribe, then relaunch once.
            </p>
          </div>
        </div>
        <div class="step" data-reveal>
          <span class="n">3</span>
          <div>
            <h3>Add your AI key (BYOK)</h3>
            <p>
              Paste your own provider API key in Settings. MacTranscribe runs entirely on
              <em>your</em> models — nothing is shared, nothing routes through us.
            </p>
          </div>
        </div>
      </div>

      <div class="reqs">
        <span><b>macOS</b> 14 Sonoma or later</span>
        <span><b>Chip</b> Apple Silicon (M1–M4)</span>
        <span><b>Signed</b> &amp; notarized (Developer ID)</span>
        <span><b>Keys</b> your own (BYOK)</span>
      </div>

      <p class="note">
        <b>Private beta.</b> If macOS warns the first time, right-click the app → Open. It's a notarized
        build, so Gatekeeper will remember your choice.
      </p>
    </div>
  </section>
</Base>

<style>
  .dl {
    padding-top: calc(var(--space-section) * 0.55);
  }
  .track {
    font-size: 12.5px;
    color: var(--faint);
    margin: 14px 0 0;
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin: 56px 0 40px;
  }
  .step {
    display: flex;
    gap: 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, #0f141c, #0b0e13);
    padding: 24px 22px;
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }
  .step:hover {
    border-color: var(--line-strong);
    transform: translateY(-3px);
  }
  .n {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border-radius: 9px;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 13px;
    color: #fff;
    background: var(--accent-grad);
    box-shadow: 0 6px 16px -8px rgba(91, 140, 255, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }
  .step h3 {
    margin: 0 0 6px;
    font-size: 15px;
  }
  .step p {
    margin: 0;
    font-size: 13px;
    color: var(--dim);
    line-height: 1.6;
  }
  .reqs {
    display: flex;
    gap: 26px;
    flex-wrap: wrap;
    color: var(--faint);
    font-size: 13px;
    border-top: 1px solid var(--line);
    padding-top: 28px;
  }
  .reqs b {
    color: var(--dim);
  }
  .note {
    font-size: 12.5px;
    color: var(--faint);
    margin-top: 22px;
    max-width: 64ch;
  }
  @media (max-width: 860px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
