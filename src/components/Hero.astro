---
import AppWindow from './AppWindow.astro';
---

<header class="hero">
  <div class="wrap" data-reveal-group>
    <div class="copy">
      <p class="eyebrow" data-reveal>
        <span class="dot" aria-hidden="true"></span> Onboarding copilot · macOS 14+ · on-device
      </p>
      <h1 data-reveal>
        Ramp up new hires in <span class="grad">days, not months</span>.
      </h1>
      <p class="sub" data-reveal>
        MacTranscribe sits in your new hire's first onboarding meetings and 1:1s, transcribes them in
        real time, and answers "how do we do X here?" the moment it comes up — in a floating window
        that stays out of the way. It turns tribal, undocumented knowledge into instant answers so
        week one is actually productive.
      </p>
      <div class="cta" data-reveal>
        <a class="btn btn-primary btn-lg" href="/login">Get started</a>
        <a class="btn btn-ghost btn-lg" href="#features">See how it works</a>
      </div>
      <ul class="req" data-reveal>
        <li><b>Free</b> tier &amp; Pro</li>
        <li><b>Captures</b> meetings &amp; 1:1s</li>
        <li><b>Private</b> — your own AI keys</li>
      </ul>
    </div>

    <div class="windowwrap" data-reveal>
      <AppWindow />
    </div>
  </div>
</header>

<style>
  .hero {
    padding: clamp(3rem, 1.5rem + 6vw, 6rem) 0 0;
    position: relative;
  }
  .copy {
    max-width: 760px;
  }
  .eyebrow {
    margin: 0 0 26px;
  }
  h1 {
    font-size: var(--text-hero);
    line-height: 0.98;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
    font-weight: 600;
    max-width: 15ch;
    text-wrap: balance;
  }
  .sub {
    font-size: clamp(1.05rem, 0.96rem + 0.5vw, 1.3rem);
    color: var(--dim);
    max-width: 56ch;
    margin: 0 0 34px;
    line-height: 1.6;
  }
  .cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }
  .req {
    list-style: none;
    padding: 0;
    color: var(--faint);
    font-size: 13px;
    margin: 18px 0 0;
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }
  .req li {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .req li::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.7;
  }
  .req li:first-child::before {
    display: none;
  }
  .req b {
    color: var(--dim);
    font-weight: 600;
  }

  /* wrapper around the app window (the stage owns its own top spacing) */
  .windowwrap {
    position: relative;
  }
</style>
