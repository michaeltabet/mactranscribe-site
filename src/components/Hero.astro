---
import AppWindow from './AppWindow.astro';
---

<header class="hero">
  <div class="wrap" data-reveal-group>
    <div class="copy">
      <p class="eyebrow" data-reveal>
        <span class="dot" aria-hidden="true"></span> macOS 14+ · Apple Silicon · on-device
      </p>
      <h1 data-reveal>
        Live transcription and an <span class="grad">AI copilot</span> for your Mac.
      </h1>
      <p class="sub" data-reveal>
        MacTranscribe listens to your call, transcribes it in real time, and answers on demand — in a
        floating window that stays out of the way. Interviews, sales calls, meetings, coding, study —
        whatever you're walking into. Runs on your own AI keys.
      </p>
      <div class="cta" data-reveal>
        <a class="btn btn-primary btn-lg" href="/download">↓ Download for macOS</a>
        <a class="btn btn-ghost btn-lg" href="#features">See what it does</a>
      </div>
      <ul class="req" data-reveal>
        <li><b>Free</b> tier &amp; Pro</li>
        <li><b>Apple Silicon</b> (M1–M4)</li>
        <li><b>BYOK</b> — your own AI keys</li>
      </ul>
    </div>

    <div class="windowwrap" data-reveal>
      <AppWindow />
    </div>
  </div>
</header>

<style>
  .hero {
    padding: clamp(3rem, 1.5rem + 6vw, 6rem) 0 0;
    position: relative;
  }
  .copy {
    max-width: 760px;
  }
  .eyebrow {
    margin: 0 0 26px;
  }
  h1 {
    font-size: var(--text-hero);
    line-height: 0.98;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
    font-weight: 600;
    max-width: 15ch;
    text-wrap: balance;
  }
  .sub {
    font-size: clamp(1.05rem, 0.96rem + 0.5vw, 1.3rem);
    color: var(--dim);
    max-width: 56ch;
    margin: 0 0 34px;
    line-height: 1.6;
  }
  .cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }
  .req {
    list-style: none;
    padding: 0;
    color: var(--faint);
    font-size: 13px;
    margin: 18px 0 0;
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }
  .req li {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .req li::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.7;
  }
  .req li:first-child::before {
    display: none;
  }
  .req b {
    color: var(--dim);
    font-weight: 600;
  }

  /* wrapper around the app window (the stage owns its own top spacing) */
  .windowwrap {
    position: relative;
  }
</style>
