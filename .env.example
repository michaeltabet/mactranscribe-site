# =============================================================================
# MacTranscribe site — environment variables
# Copy to `.env` for local dev. In production these come from a Kubernetes Secret.
# NEVER commit a real `.env`. Every secret is read at RUNTIME, so `npm run build`
# works even with this file absent.
# =============================================================================

# ---- Site ----
# Canonical public origin (no trailing slash). Used for OIDC redirect URIs,
# Stripe success/cancel URLs, and canonical tags.
PUBLIC_BASE_URL=https://mactranscribe.michaeltabet.com

# HS256 secret used to sign the httpOnly session + OIDC-handshake cookies.
# Generate: `openssl rand -base64 48`  (use a long, random value)
SESSION_SECRET=change-me-to-a-long-random-string

# Set to "false" ONLY for local http dev so the Secure cookie flag is dropped.
# Leave unset (defaults to true) in production.
# SESSION_COOKIE_SECURE=false

# =============================================================================
# Keycloak — user authentication (Authorization Code + PKCE)
# =============================================================================
# Realm issuer URL: <keycloak-root>/realms/mactranscribe
KEYCLOAK_ISSUER=https://auth.michaeltabet.com/realms/mactranscribe
# Confidential web client (added to keycloak/mactranscribe-realm.json as "mactranscribe-web")
KEYCLOAK_CLIENT_ID=mactranscribe-web
KEYCLOAK_CLIENT_SECRET=change-me-web-client-secret

# =============================================================================
# Keycloak Admin API — used by billing webhooks to grant/revoke the `pro` role
# via the "mactranscribe-billing" service-account client.
# =============================================================================
# Optional: realm name (defaults to "mactranscribe")
# KEYCLOAK_REALM=mactranscribe
# Optional: Keycloak root URL. If unset, it is derived from KEYCLOAK_ISSUER by
# stripping the trailing /realms/<realm>.
# KEYCLOAK_ADMIN_BASE_URL=https://auth.michaeltabet.com
# Optional: service-account clientId (defaults to "mactranscribe-billing")
# KEYCLOAK_ADMIN_CLIENT_ID=mactranscribe-billing
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-billing-client-secret

# =============================================================================
# Google social login (configured INSIDE Keycloak as the "google" IdP).
# These are NOT read by the site directly; they populate the realm import's
# ${GOOGLE_CLIENT_ID} / ${GOOGLE_CLIENT_SECRET} placeholders (or set them in the
# Keycloak admin UI). Listed here for completeness.
# =============================================================================
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=change-me-google-secret

# =============================================================================
# Stripe — Pro subscription checkout + webhook
# =============================================================================
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Recurring Price (subscription) for the $12/mo Pro plan.
STRIPE_PRICE_ID=price_xxx
# Signing secret for the webhook endpoint (Stripe Dashboard > Webhooks).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# =============================================================================
# PayPal — subscription alternative
# =============================================================================
PAYPAL_CLIENT_ID=change-me-paypal-client-id
# Subscription plan id (PayPal Dashboard > Subscriptions > Plans).
PAYPAL_PLAN_ID=P-XXXXXXXXXXXXXXXX
# Optional: "live" (default) or "sandbox"
# PAYPAL_ENV=live
# Optional: webhook id — when set, the PayPal webhook acts on events; when unset
# it acknowledges without acting (stub mode) until signature verification is wired.
# PAYPAL_WEBHOOK_ID=change-me-paypal-webhook-id

# =============================================================================
# Server
# =============================================================================
# Port the standalone Node server listens on (defaults to 4321).
# PORT=4321
# HOST=0.0.0.0
